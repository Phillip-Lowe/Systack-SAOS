# --- Secrets & Credentials ---
*.env
.env.*
!.env.example
*.key
*.pem
*.crt
*.p12
*.pfx
*secret*
*credential*
*token*
*password*
*api_key*

# --- OAuth / API Configs ---
client_secret*.json
*oauth*.json
*google*.json
*maps*.json

# --- Directories that should never be committed ---
credentials/
secrets/
tokens/
auth/

# --- Dependencies ---
node_modules/
vendor/
__pycache__/
*.egg-info/

# --- OS & IDE ---
.DS_Store
.idea/
.vscode/
*.swp
*.swo

# --- Logs ---
*.log
logs/

# --- Runtime / Generated ---
*.backup*
*.backup.*
index.html.backup*
amp
n8n-postgres-start.sh

# --- Memory runtime (source is tracked, generated is not) ---
memory/.dreams/
memory/session_state.db
memory/session_state.db-journal
memory/dreaming/

# --- Large Media Files ---
*.mp4
*.mp3
*.mov
*.avi
*.mkv
*.wmv
*.flv
*.webm

# --- Large Images / Archives ---
*.zip
*.tar.gz
*.tar.bz2
