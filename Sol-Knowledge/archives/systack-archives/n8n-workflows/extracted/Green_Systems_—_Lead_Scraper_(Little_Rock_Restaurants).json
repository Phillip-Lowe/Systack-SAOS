      "id": "http-website-01",
      "name": "HTTP Request \u2014 Check Website",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1344,
        544
      ],
      "continueOnFail": true
    },
    {
      "parameters": {
        "jsCode": "const restaurant = $input.first().json;\nconst html = $json.data || '';\nconst htmlLower = html.toLowerCase();\n\nconst hasOrderOnline = /order.*online|online.*order|order.*now/i.test(htmlLower);\nconst hasDoordash = /doordash|door dash/i.test(htmlLower);\nconst hasUbereats = /uber\\s*eats|ubereats/i.test(htmlLower);\nconst hasGrubhub = /grubhub|grub hub/i.test(htmlLower);\nconst hasSquare = /square|squareup/i.test(htmlLower);\nconst hasToast = /toasttab|toast/i.test(htmlLower);\nconst hasChownow = /chownow|chow now/i.test(htmlLower);\n\nlet score = 0;\nlet reasons = [];\n\nif (restaurant.website) {\n  score += 1;\n  reasons.push('has_website');\n}\n\nif (!hasOrderOnline) {\n  score += 2;\n  reasons.push('no_online_ordering');\n}\n\nif (hasDoordash || hasUbereats || hasGrubhub) {\n  score += 1;\n  reasons.push('on_third_party_platforms');\n}\n\nif (restaurant.rating >= 3.5) {\n  score += 1;\n  reasons.push('good_rating');\n}\n\nif (restaurant.phone) {\n  score += 1;\n  reasons.push('has_phone');\n}\n\nlet category = 'Skip';\nif (score >= 4) category = 'Qualified';\nelse if (score >= 2) category = 'Research';\n\nreturn [{ json: {\n  ...restaurant,\n  website_analysis: {\n    has_order_online: hasOrderOnline,\n    has_doordash: hasDoordash,\n    has_ubereats: hasUbereats,\n    has_grubhub: hasGrubhub,\n    has_square: hasSquare,\n    has_toast: hasToast,\n    has_chownow: hasChownow\n  },\n  score,\n  score_reasons: reasons,\n  category,\n  stage: 'New',\n  owner: 'Green',\n  created_date: new Date().toISOString(),\n  source: 'google_maps_scraper'\n} }];"
      },
