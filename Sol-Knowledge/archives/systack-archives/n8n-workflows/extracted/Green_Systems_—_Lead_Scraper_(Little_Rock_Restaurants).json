    {
      "parameters": {
        "jsCode": "const detail = $json.result || {};\nconst restaurant = $input.first().json;\nreturn [{ json: {\n  ...restaurant,\n  website: detail.website || '',\n  phone: detail.formatted_phone_number || ''\n} }];"
