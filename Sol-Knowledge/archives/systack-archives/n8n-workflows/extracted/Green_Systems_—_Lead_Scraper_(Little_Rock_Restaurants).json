    {
      "parameters": {
        "jsCode": "const results = $json.results || [];\nconst restaurants = results.map(place => ({\n  place_id: place.place_id,\n  name: place.name,\n  address: place.vicinity,\n  rating: place.rating || 0,\n  review_count: place.user_ratings_total || 0,\n  types: place.types?.join(', ') || '',\n  lat: place.geometry?.location?.lat,\n  lng: place.geometry?.location?.lng\n}));\nreturn restaurants.map(r => ({ json: r }));"
      },
      "id": "code-extract-01",
      "name": "Code \u2014 Extract Restaurants",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        752,
        544
      ]
