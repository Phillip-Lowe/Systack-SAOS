      "id": "c9067626-4bd2-4ac6-bb35-fe10a1026b46",
      "name": "HTTP \u2014 Read Open_Hours",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [
        720,
        400
      ]
    },
    {
      "parameters": {
        "functionCode": "\n// America/Chicago hours gate from Open_Hours\nfunction getChicagoNow() {\n  const fmt = new Intl.DateTimeFormat('en-US', { timeZone: 'America/Chicago', hourCycle: 'h23', year:'numeric', month:'2-digit', day:'2-digit', hour:'2-digit', minute:'2-digit', second:'2-digit', weekday:'short' });\n  const parts = Object.fromEntries(fmt.formatToParts(new Date()).map(p => [p.type, p.value]));\n  const map = { Sun:0, Mon:1, Tue:2, Wed:3, Thu:4, Fri:5, Sat:6 };\n  return { hour: +parts.hour, minute: +parts.minute, dow: map[parts.weekday] };\n}\nfunction parseHM(s){ const [h,m] = String(s).split(':').map(Number); return {h,m}; }\nconst rows = $json.data || $json.rows || [];\nlet data = [];\nif (Array.isArray(rows) && rows.length) {\n  if (Array.isArray(rows[0])) {\n    for (const r of rows) data.push({ dow:+r[0], open_local:r[1], close_local:r[2], is_open:String(r[3]).toUpperCase() });\n  } else if (typeof rows[0] === 'object') {\n    data = rows.map(r => ({ dow:+r.dow, open_local:r.open_local, close_local:r.close_local, is_open:String(r.is_open).toUpperCase() }));\n  }\n}\nconst now = getChicagoNow();\nconst today = data.find(r => r.dow === now.dow);\nif (!today || today.is_open !== 'TRUE') return [{ json: { isOpen:false, reason:'Closed today', window:null } }];\nconst o = parseHM(today.open_local), c = parseHM(today.close_local);\nconst nowMin = now.hour*60 + now.minute, openMin = o.h*60 + o.m, closeMin = c.h*60 + c.m;\nconst inWindow = nowMin >= openMin && nowMin <= closeMin;\nreturn [{ json: { isOpen: inWindow, reason: inWindow ? 'OK' : `Open ${today.open_local}\u2013${today.close_local}`, window: today } }];\n"
      },
