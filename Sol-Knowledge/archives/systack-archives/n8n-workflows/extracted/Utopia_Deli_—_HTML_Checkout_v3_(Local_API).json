    {
      "parameters": {
        "functionCode": "\n// Labels like [GROUP|MOD] Label +$x.xx\nconst selected = [];\nconst priceRx = /\\+\\$(\\d+(?:\\.\\d{1,2})?)$/;\nfor (const [k,v] of Object.entries($json)) {\n  if (!v) continue; const label = String(v).trim(); if (!label.startsWith('[')) continue;\n  const tag = label.match(/^\\[([A-Z0-9_]+)\\|([A-Z0-9_]+)\\]/i); if (!tag) continue;\n  const group = tag[1].toUpperCase(), mod = tag[2].toUpperCase();\n  const pm = label.match(priceRx); const price_cents = pm ? Math.round(parseFloat(pm[1])*100) : 0;\n  selected.push({ group, mod, label, price_cents });\n}\nreturn [{ json: { modifiers: selected } }];\n"
      },
      "id": "1d1bb413-f889-4b5c-b2d6-1525f83cfea6",
      "name": "Function \u2014 Collect Modifiers",
      "type": "n8n-nodes-base.function",
      "typeVersion": 1,
      "position": [
        1952,
        544
      ]
    },
    {
      "parameters": {
        "functionCode": "\n// Build entr\u00e9e + modifiers\nconst entreeTitle = $item(0).$node[\"Set \u2014 Normalize\"].json[\"order_input.entree\"];\nconst rows = $item(0).$node[\"HTTP \u2014 Read Menu_Catalog\"].json.data || [];\nlet entree = null; // rows: [sku, title, price_cents, square_id, is_active]\nfor (const r of rows) {\n  const [sku,title,price_cents,square_id,is_active] = r;\n  if (String(title).trim()===String(entreeTitle).trim() && String(is_active).toUpperCase()==='TRUE') { entree={sku,title,price_cents:+price_cents,square_catalog_object_id:square_id}; break; }\n}\nif (!entree) return [{ json: { error: 'Selected entr\u00e9e unavailable' } }];\nconst mods = $item(0).$node[\"Function \u2014 Collect Modifiers\"].json.modifiers || [];\nconst qty=1; const entreePrice=+entree.price_cents; const modsTotal = mods.reduce((s,m)=>s+ +(m.price_cents||0), 0);\nconst subtotal = (entreePrice + modsTotal) * qty;\nconst line_items=[{ sku:entree.sku, title:entree.title, quantity:qty, unit_price_cents:entreePrice, amount_cents:entreePrice*qty, modifiers:mods }];\nfor (const m of mods) if ((m.price_cents||0)>0) line_items.push({ sku:`MOD_${m.group}_${m.mod}`, title:m.label.replace(/\\[.*?\\]\\s*/, ''), quantity:1, unit_price_cents:+m.price_cents, amount_cents:+m.price_cents });\nreturn [{ json: { entree, order_calc: { line_items, subtotal_cents: subtotal } } }];\n"
      },
