    {
      "parameters": {
        "functionCode": "\n// Hardcoded 9.75% tax rate for Little Rock / Pulaski County, AR\nconst TAX_RATE = 9.75;\n\nconst subtotal = $item(0).$node[\"Function \u2014 Build Price\"].json.order_calc.subtotal_cents;\nconst tax = Math.round(subtotal * (TAX_RATE / 100));\nconst total = subtotal + tax;\n\nreturn [{ json: { pricing: { rate_percent: TAX_RATE, subtotal_cents: subtotal, tax_cents: tax, total_cents: total } } }];\n"
