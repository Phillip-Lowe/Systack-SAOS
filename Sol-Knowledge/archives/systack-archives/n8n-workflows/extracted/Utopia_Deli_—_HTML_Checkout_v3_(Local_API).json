    {
      "parameters": {
        "functionCode": "\nconst row = [\n  new Date().toISOString(),\n  $item(0).$node['Set \u2014 Normalize'].json['customer.name'],\n  $item(0).$node['Set \u2014 Normalize'].json['customer.email'],\n  $item(0).$node['Set \u2014 Normalize'].json['customer.phone'],\n  $item(0).$node['Set \u2014 Normalize'].json['geo.city'],\n  $item(0).$node['Set \u2014 Normalize'].json['geo.county'],\n  $item(0).$node['Function \u2014 Build Price'].json.entree.sku,\n  JSON.stringify($item(0).$node['Function \u2014 Collect Modifiers'].json.modifiers||[]),\n  $item(0).$node['Function \u2014 Compute Tax & Totals'].json.pricing.subtotal_cents,\n  $item(0).$node['Function \u2014 Compute Tax & Totals'].json.pricing.tax_cents,\n  $item(0).$node['Function \u2014 Compute Tax & Totals'].json.pricing.total_cents,\n  $item(0).$node['Set \u2014 Confirmation'].json.square_link,\n  'pending_payment'\n];\nreturn [{ json: { gs_append: [row] } }];\n"
