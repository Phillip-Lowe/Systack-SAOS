[{"parameters":{"pollTimes":{"item":[{"mode":"everyMinute","minute":1}]},"mailbox":"INBOX","options":{"downloadAttachments":true}},"id":"imap-trigger","name":"Invoice Email Trigger","type":"n8n-nodes-base.emailReadImap","typeVersion":2,"position":[250,300]},{"parameters":{"conditions":{"options":{"caseSensitive":true,"leftValue":"","typeValidation":"strict"},"conditions":[{"id":"cond-has-attachment","leftValue":"={{ $json.attachments && $json.attachments.length > 0 }}","rightValue":"true","operator":{"type":"boolean","operation":"equals"}}],"combinator":"and"}},"id":"if-has-attachment","name":"Has Attachment?","type":"n8n-nodes-base.if","typeVersion":2,"position":[450,300]},{"parameters":{"jsCode":"var input = $input.first().json;\nvar atts = input.attachments || [];\nvar pdf = null;\nfor (var i = 0; i < atts.length; i++) {\n  var a = atts[i];\n  if (a.fileName && a.fileName.toLowerCase().endsWith('.pdf')) {\n    pdf = a;\n    break;\n  }\n}\n\nif (!pdf) {\n  return [{ json: { error: 'NO_PDF_ATTACHMENT', subject: input.subject } }];\n}\n\nreturn [{\n  json: {\n    invoice_id: 'INV-' + new Date().getTime(),\n    from_email: input.from,\n    subject: input.subject,\n    received_at: input.date,\n    pdf_filename: pdf.fileName,\n    pdf_binary: pdf.content\n  }\n}];"},"id":"extract-pdf","name":"Extract PDF","type":"n8n-nodes-base.code","typeVersion":2,"position":[650,150]},{"parameters":{"operation":"write","fileName":"={{ '/data/invoices/' + $json.invoice_id + '.pdf' }}","fileContent":"={{ $json.pdf_binary }}","options":{}},"id":"save-pdf","name":"Save PDF","type":"n8n-nodes-base.writeBinaryFile","typeVersion":1,"position":[850,150]},{"parameters":{"method":"POST","url":"http://localhost:8000/extract-invoice","sendBody":true,"contentType":"json","body":"={{ JSON.stringify({ pdf_path: '/data/invoices/' + $json.invoice_id + '.pdf', invoice_id: $json.invoice_id }) }}","options":{}},"id":"call-parser","name":"Call Invoice Parser","type":"n8n-nodes-base.httpRequest","typeVersion":4.1,"position":[1050,150]},{"parameters":{"operation":"executeQuery","query":"INSERT INTO invoices (invoice_id, from_email, subject, received_at, pdf_filename, extracted_data, status, created_at) VALUES ('{{ $json.invoice_id }}', '{{ $json.from_email }}', '{{ $json.subject }}', '{{ $json.received_at }}', '{{ $json.pdf_filename }}', '{{ JSON.stringify($json.extracted) }}', 'pending_review', NOW());"},"id":"postgres-invoice","name":"Log to Postgres","type":"n8n-nodes-base.postgres","typeVersion":2.2,"position":[1250,150],"credentials":{"postgres":{"id":"local-postgres","name":"Local Postgres"}}},{"parameters":{"subject":"={{ 'Invoice Received: ' + $json.invoice_id }}","message":"={{ 'From: ' + $json.from_email + '\\nTotal: ' + ($json.extracted && $json.extracted.total_amount || 'N/A') + '\\nVendor: ' + ($json.extracted && $json.extracted.vendor_name || 'N/A') + '\\nStored: /data/invoices/' + $json.invoice_id + '.pdf' }}"},"id":"sms-notify","name":"SMS Notify Owner","type":"n8n-nodes-base.twilio","typeVersion":1,"position":[1450,150]},{"parameters":{"options":{}},"id":"no-op-skip","name":"Skip Non-PDF","type":"n8n-nodes-base.noOp","typeVersion":1,"position":[650,450]}]
