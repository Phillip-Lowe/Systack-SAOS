        function requestSetup(serviceName) {
            // Create a new chat conversation requesting setup
            const msg = `Please set up ${serviceName} for my account.`;
            
            // If we're not in chat tab, switch to it
            showTab('chat');
            
            // If no conversation exists, create one
            if (!currentConvId) {
                createConversation().then(() => {
                    setTimeout(() => {
                        document.getElementById('messageInput').value = msg;
                        sendMessage();
                    }, 500);
                });
            } else {
                document.getElementById('messageInput').value = msg;
                sendMessage();
            }
        }

        async function loadActivityLog() {
            // This would fetch from execution_log API endpoint
            // For now, show placeholder with real structure
            const activities = [
                { time: '10:42 AM', agent: 'SOL', action: 'Processed invoice #2847', detail: 'Extracted $847.23 from vendor@example.com', status: 'success' },
                { time: '10:38 AM', agent: 'ASSEMBLY', action: 'Deployed workflow update', detail: 'Invoice extraction pipeline v2.1', status: 'success' },
                { time: '10:15 AM', agent: 'SOL', action: 'Sent weekly campaign', detail: '346 subscribers, 89% delivery rate', status: 'success' },
                { time: '9:52 AM', agent: 'VALI', action: 'Validation check', detail: '3 invoices flagged for review', status: 'warning' },
            ];
            
            return activities;
        }

        async function loadActivity() {
            // Fetch real execution log from API
            try {
                const tasks = await api('GET', '/api/portal/tasks');
                const recent = tasks.slice(0, 20);
                
                document.getElementById('activityContent').innerHTML = recent.length ? `
                    <div style="display:flex; flex-direction:column; gap:8px">
                        ${recent.map(t => {
                            const statusColor = t.status === 'DONE' ? 'var(--green)' : 
                                               t.status === 'FAILED' ? 'var(--red)' : 
                                               t.status === 'RUNNING' ? 'var(--accent-bright)' : 'var(--amber)';
                            const statusIcon = t.status === 'DONE' ? '✅' : 
                                              t.status === 'FAILED' ? '❌' : 
                                              t.status === 'RUNNING' ? '🔄' : '⏳';
                            return `
                            <div style="background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius-sm); padding:14px 18px; display:flex; align-items:flex-start; gap:14px">
                                <div style="font-size:20px; flex-shrink:0; margin-top:2px">${statusIcon}</div>
                                <div style="flex:1; min-width:0">
                                    <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px">
                                        <span style="font-weight:700; color:white; font-size:13px">${t.task_type}</span>
                                        <span class="status-pill status-${t.status.toLowerCase()}">${t.status}</span>
                                        <span style="font-size:11px; color:var(--text-dim); margin-left:auto">${formatTime(t.created_at)}</span>
                                    </div>
                                    <div style="font-size:12px; color:var(--text-muted)">
                                        Agent: ${t.assigned_agent || 'Unassigned'} • Priority: ${t.priority || '—'}
                                    </div>
                                    ${t.error_message ? `<div style="margin-top:6px; padding:8px 12px; background:rgba(239,68,68,0.08); border-radius:6px; font-size:12px; color:var(--red)">${escapeHtml(t.error_message)}</div>` : ''}
                                    ${t.status === 'DONE' && t.completed_at ? `<div style="margin-top:4px; font-size:11px; color:var(--green)">Completed ${formatTime(t.completed_at)}</div>` : ''}
                                </div>
                            </div>
                            `;
                        }).join('')}
                    </div>
                ` : '<div style="color:var(--text-dim); text-align:center; padding:40px">No activity yet. Tasks will appear here as agents process your requests.</div>';
            } catch(e) {
                document.getElementById('activityContent').innerHTML = '<div style="color:var(--red); text-align:center; padding:40px">Failed to load activity log.</div>';
            }
        }

        function getDocsForTier(tier) {
            const base = [
                { icon: '📄', name: 'Quick Start Guide v3.0', desc: 'Get started with your SAOS deployment', url: '/SAOS-Quick-Start-Guide-v3.0.pdf' },
                { icon: '📘', name: 'Service Manual v3.0', desc: 'Complete reference for your SAOS system', url: '/SAOS-Service-Manual-v3.0.pdf' },
                { icon: '🏗️', name: 'Architecture Overview v2.0', desc: 'Technical architecture and component details', url: '/SAOS-Architecture-Overview-v2.0.pdf' },
            ];

            const extra = {
                'enterprise': [
                    { icon: '📋', name: 'Enterprise Deployment Guide', desc: 'On-premise setup and compliance configuration', url: '/SyStack-Enterprise-Deployment-Guide-v1.0.pdf' },
                ],
                'private': [
                    { icon: '📋', name: 'Enterprise Deployment Guide', desc: 'On-premise setup and compliance configuration', url: '/SyStack-Enterprise-Deployment-Guide-v1.0.pdf' },
                ],
            };

            return [...base, ...(extra[tier] || [])];
        }

        // ── UTILS ────────────────────────────────────────────────
        function formatTime(iso) {
            if (!iso) return '';
            const d = new Date(iso);
            const now = new Date();
            const diff = (now - d) / 1000;

            if (diff < 60) return 'just now';
            if (diff < 3600) return `${Math.floor(diff/60)}m ago`;
            if (diff < 86400) return `${Math.floor(diff/3600)}h ago`;
            return d.toLocaleDateString();
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function scrollToBottom() {
            const container = document.getElementById('messagesContainer');
            if (container) container.scrollTop = container.scrollHeight;
        }

        // Enter to send, Shift+Enter for new line
        document.addEventListener('keydown', (e) => {
            if (e.target.id === 'messageInput' && e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });

        // Auto-resize textarea
        document.addEventListener('input', (e) => {
            if (e.target.id === 'messageInput') {
                e.target.style.height = '42px';
                e.target.style.height = Math.min(e.target.scrollHeight, 120) + 'px';
            }
        });

        // ── BOOT ─────────────────────────────────────────────────
        if (token) {
            initApp();
        }
    </script>
</body>
