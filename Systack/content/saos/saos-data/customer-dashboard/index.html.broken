<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SAOS Client Portal — Systack</title>
    <style>
        :root {
            --bg-deep: #001a2d;
            --bg-card: rgba(255,255,255,0.04);
            --bg-hover: rgba(255,255,255,0.06);
            --border: rgba(255,255,255,0.08);
            --border-hover: rgba(0,161,219,0.3);
            --accent: #00a1db;
            --accent-bright: #00c5e0;
            --text: #e2e8f0;
            --text-muted: #94a3b8;
            --text-dim: #64748b;
            --green: #22c55e;
            --amber: #f59e0b;
            --red: #ef4444;
            --purple: #8b5cf6;
            --radius: 14px;
            --radius-sm: 10px;
            --chat-bg: #0d2137;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', sans-serif;
            background: var(--bg-deep);
            color: var(--text);
            min-height: 100vh;
            line-height: 1.5;
            overflow: hidden;
        }

        /* ── Navigation ── */
        .nav {
            background: rgba(0,26,45,0.95);
            backdrop-filter: blur(12px);
            border-bottom: 1px solid var(--border);
            padding: 0 24px;
            display: flex;
            align-items: center;
            height: 56px;
            flex-shrink: 0;
        }
        .nav-brand {
            display: flex;
            align-items: center;
            gap: 8px;
            font-weight: 700;
            font-size: 16px;
            color: white;
            text-decoration: none;
        }
        .nav-links {
            display: flex;
            gap: 4px;
            margin-left: 32px;
        }
        .nav-link {
            color: var(--text-muted);
            text-decoration: none;
            padding: 6px 14px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 500;
            transition: all 0.2s;
            cursor: pointer;
            border: none;
            background: none;
            font-family: inherit;
        }
        .nav-link:hover, .nav-link.active {
            color: white;
            background: rgba(255,255,255,0.06);
        }
        .nav-link.active { color: var(--accent-bright); }
        .nav-right {
            margin-left: auto;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .nav-avatar {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--accent), var(--purple));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 700;
            color: white;
        }
        .nav-client-name {
            font-size: 13px;
            color: var(--text);
            font-weight: 500;
        }
        .badge-unread {
            background: var(--red);
            color: white;
            font-size: 10px;
            font-weight: 700;
            padding: 2px 6px;
            border-radius: 10px;
            min-width: 18px;
            text-align: center;
        }

        /* ── Login Screen ── */
        .login-screen {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            background: linear-gradient(135deg, #001a2d 0%, #0d2137 100%);
        }
        .login-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 48px;
            width: 100%;
            max-width: 420px;
            text-align: center;
        }
        .login-card h1 {
            font-size: 24px;
            margin-bottom: 8px;
            color: white;
        }
        .login-card p {
            color: var(--text-muted);
            margin-bottom: 32px;
        }
        .form-group {
            margin-bottom: 20px;
            text-align: left;
        }
        .form-group label {
            display: block;
            font-size: 13px;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 6px;
        }
        .form-group input {
            width: 100%;
            padding: 12px 16px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            color: white;
            font-size: 15px;
            outline: none;
            transition: all 0.2s;
        }
        .form-group input:focus {
            border-color: var(--accent);
            background: rgba(255,255,255,0.08);
        }
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 10px 20px;
            border-radius: var(--radius-sm);
            font-size: 13px;
            font-weight: 600;
            text-decoration: none;
            transition: all 0.2s;
            border: none;
            cursor: pointer;
            font-family: inherit;
        }
        .btn-primary {
            background: var(--accent);
            color: white;
            width: 100%;
        }
        .btn-primary:hover { background: #007da9; }
        .btn-secondary {
            background: rgba(255,255,255,0.06);
            color: var(--text);
            border: 1px solid var(--border);
        }
        .btn-secondary:hover { background: rgba(255,255,255,0.1); }
        .btn-sm {
            padding: 6px 12px;
            font-size: 12px;
        }
        .error-msg {
            color: var(--red);
            font-size: 13px;
            margin-top: 12px;
        }

        /* ── Main Layout ── */
        .app-container {
            display: none;
            height: 100vh;
            flex-direction: column;
        }
        .app-container.active {
            display: flex;
        }
        .app-body {
            flex: 1;
            display: flex;
            overflow: hidden;
        }

        /* ── Sidebar ── */
        .sidebar {
            width: 280px;
            background: rgba(0,26,45,0.95);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            flex-shrink: 0;
        }
        .sidebar-header {
            padding: 16px;
            border-bottom: 1px solid var(--border);
        }
        .sidebar-header h2 {
            font-size: 14px;
            color: white;
            margin-bottom: 10px;
        }
        .new-chat-btn {
            width: 100%;
        }
        .conversation-list {
            flex: 1;
            overflow-y: auto;
            padding: 6px;
        }
        .conversation-item {
            padding: 10px 12px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            transition: all 0.2s;
            margin-bottom: 2px;
            position: relative;
        }
        .conversation-item:hover {
            background: var(--bg-hover);
        }
        .conversation-item.active {
            background: rgba(0,161,219,0.1);
            border: 1px solid var(--border-hover);
        }
        .conv-title {
            font-size: 13px;
            font-weight: 600;
            color: white;
            margin-bottom: 2px;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .conv-preview {
            font-size: 11px;
            color: var(--text-dim);
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .conv-meta {
            display: flex;
            align-items: center;
            gap: 6px;
            margin-top: 2px;
        }
        .conv-time {
            font-size: 10px;
            color: var(--text-dim);
        }
        .conv-unread {
            background: var(--red);
            color: white;
            font-size: 10px;
            font-weight: 700;
            padding: 1px 5px;
            border-radius: 8px;
        }

        /* ── Chat Area ── */
        .chat-area {
            flex: 1;
            display: flex;
            flex-direction: column;
            background: var(--chat-bg);
            min-width: 0;
        }
        .chat-header {
            padding: 12px 20px;
            border-bottom: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-shrink: 0;
        }
        .chat-header-info h3 {
            font-size: 15px;
            color: white;
        }
        .chat-header-info p {
            font-size: 11px;
            color: var(--text-dim);
        }
        .chat-status {
            display: flex;
            align-items: center;
            gap: 6px;
            font-size: 12px;
            color: var(--green);
        }
        .status-dot {
            width: 7px;
            height: 7px;
            border-radius: 50%;
            background: var(--green);
            box-shadow: 0 0 6px rgba(34,197,94,0.5);
        }

        /* ── Messages ── */
        .messages-container {
            flex: 1;
            overflow-y: auto;
            padding: 16px 20px;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .message {
            display: flex;
            gap: 10px;
            max-width: 75%;
            animation: fadeIn 0.3s ease;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(8px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .message.client {
            align-self: flex-end;
            flex-direction: row-reverse;
        }
        .message.agent {
            align-self: flex-start;
        }
        .message.system {
            align-self: center;
            max-width: 55%;
        }
        .message-avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
        }
        .message.client .message-avatar {
            background: linear-gradient(135deg, var(--accent), var(--purple));
        }
        .message.agent .message-avatar {
            background: rgba(255,255,255,0.1);
        }
        .message.system .message-avatar {
            display: none;
        }
        .message-content {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 10px 14px;
            color: var(--text);
            font-size: 13px;
            line-height: 1.5;
        }
        .message.client .message-content {
            background: rgba(0,161,219,0.15);
            border-color: rgba(0,161,219,0.3);
        }
        .message.system .message-content {
            background: rgba(245,158,11,0.08);
            border-color: rgba(245,158,11,0.2);
            color: var(--amber);
            font-size: 12px;
            text-align: center;
        }
        .message-meta {
            font-size: 10px;
            color: var(--text-dim);
            margin-top: 3px;
            display: flex;
            align-items: center;
            gap: 4px;
        }
        .message.client .message-meta {
            justify-content: flex-end;
        }
        .task-pill {
            display: inline-flex;
            align-items: center;
            gap: 3px;
            padding: 1px 7px;
            border-radius: 10px;
            font-size: 10px;
            font-weight: 600;
            background: rgba(0,161,219,0.15);
            color: var(--accent-bright);
        }

        /* ── Input Area ── FIXED: proper proportions ── */
        .input-area {
            padding: 12px 20px;
            border-top: 1px solid var(--border);
            display: flex;
            gap: 10px;
            align-items: center;
            flex-shrink: 0;
        }
        .message-input {
            flex: 1;
            padding: 10px 14px;
            background: rgba(255,255,255,0.05);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            color: white;
            font-size: 14px;
            outline: none;
            resize: none;
            height: 42px;
            line-height: 1.4;
            font-family: inherit;
            transition: border-color 0.2s, background 0.2s;
        }
        .message-input:focus {
            border-color: var(--accent);
            background: rgba(255,255,255,0.08);
        }
        .message-input::placeholder {
            color: var(--text-dim);
        }
        .send-btn {
            padding: 0 18px;
            height: 42px;
            font-size: 13px;
            font-weight: 600;
            background: var(--accent);
            color: white;
            border: none;
            border-radius: var(--radius-sm);
            cursor: pointer;
            transition: background 0.2s;
            flex-shrink: 0;
            white-space: nowrap;
        }
        .send-btn:hover { background: #007da9; }

        /* ── Empty State ── */
        .empty-chat {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100%;
            color: var(--text-dim);
            text-align: center;
            padding: 32px;
        }
        .empty-chat-icon {
            font-size: 48px;
            margin-bottom: 12px;
            opacity: 0.4;
        }
        .empty-chat h3 {
            font-size: 16px;
            color: var(--text-muted);
            margin-bottom: 6px;
        }
        .empty-chat p {
            font-size: 13px;
            max-width: 360px;
        }

        /* ── Typing Indicator ── */
        .typing-indicator {
            display: none;
            align-items: center;
            gap: 6px;
            padding: 8px 20px;
            color: var(--text-dim);
            font-size: 12px;
        }
        .typing-indicator.active {
            display: flex;
        }
        .typing-dots {
            display: flex;
            gap: 3px;
        }
        .typing-dots span {
            width: 5px;
            height: 5px;
            border-radius: 50%;
            background: var(--text-dim);
            animation: typingBounce 1.4s ease-in-out infinite;
        }
        .typing-dots span:nth-child(2) { animation-delay: 0.2s; }
        .typing-dots span:nth-child(3) { animation-delay: 0.4s; }
        @keyframes typingBounce {
            0%, 60%, 100% { transform: translateY(0); }
            30% { transform: translateY(-3px); }
        }

        /* ── Content Tabs (Dashboard, Tasks, Docs, Services) ── */
        .content-tab {
            flex: 1;
            overflow-y: auto;
            padding: 24px 32px;
        }
        .content-tab h2 {
            color: white;
            font-size: 20px;
            margin-bottom: 20px;
        }
        .content-tab h3 {
            color: var(--text);
            font-size: 15px;
            margin: 24px 0 12px;
        }

        /* ── Metric Cards ── */
        .metrics-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 14px;
            margin-bottom: 24px;
        }
        .metric-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 18px 20px;
        }
        .metric-card .metric-label {
            font-size: 12px;
            color: var(--text-muted);
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .metric-card .metric-value {
            font-size: 28px;
            font-weight: 800;
            color: white;
        }
        .metric-card .metric-sub {
            font-size: 11px;
            color: var(--text-dim);
            margin-top: 4px;
        }

        /* ── Agent Cards ── */
        .agents-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
            gap: 10px;
        }
        .agent-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 14px;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .agent-card .agent-icon {
            font-size: 24px;
            flex-shrink: 0;
        }
        .agent-card .agent-name {
            font-weight: 700;
            color: white;
            font-size: 13px;
        }
        .agent-card .agent-status {
            font-size: 11px;
            color: var(--text-dim);
        }
        .agent-card .agent-role {
            font-size: 10px;
            color: var(--text-dim);
            margin-top: 1px;
        }

        /* ── Service Cards (NEW — tier-specific) ── */
        .services-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 14px;
        }
        .service-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px;
            transition: border-color 0.2s;
        }
        .service-card:hover {
            border-color: var(--border-hover);
        }
        .service-card .svc-icon {
            font-size: 28px;
            margin-bottom: 10px;
        }
        .service-card .svc-name {
            font-weight: 700;
            color: white;
            font-size: 14px;
            margin-bottom: 4px;
        }
        .service-card .svc-desc {
            font-size: 12px;
            color: var(--text-muted);
            line-height: 1.5;
            margin-bottom: 10px;
        }
        .service-card .svc-status {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            font-size: 11px;
            font-weight: 600;
            padding: 3px 10px;
            border-radius: 12px;
        }
        .svc-active {
            background: rgba(34,197,94,0.12);
            color: var(--green);
        }
        .svc-pending {
            background: rgba(245,158,11,0.12);
            color: var(--amber);
        }
        .svc-inactive {
            background: rgba(100,116,139,0.12);
            color: var(--text-dim);
        }
        .svc-note {
            font-size: 11px;
            color: var(--text-dim);
            margin-top: 6px;
            font-style: italic;
        }
        .svc-meta {
            display: flex;
            align-items: center;
            gap: 8px;
            margin-top: 8px;
            flex-wrap: wrap;
        }
        .svc-last-run {
            font-size: 11px;
            color: var(--text-dim);
        }
        .svc-runs-today {
            font-size: 11px;
            color: var(--accent-bright);
            font-weight: 600;
        }

        /* ── Tier Badge ── */
        .tier-badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 700;
        }
        .tier-personal { background: rgba(139,92,246,0.15); color: var(--purple); }
        .tier-personal-plus { background: rgba(0,161,219,0.15); color: var(--accent-bright); }
        .tier-business { background: rgba(34,197,94,0.12); color: var(--green); }
        .tier-enterprise { background: rgba(245,158,11,0.12); color: var(--amber); }
        .tier-private { background: rgba(239,68,68,0.12); color: var(--red); }
        .tier-accelerate { background: rgba(0,197,224,0.12); color: var(--accent-bright); }

        /* ── Task Table ── */
        .task-table {
            width: 100%;
            border-collapse: collapse;
        }
        .task-table th {
            padding: 10px 14px;
            border-bottom: 1px solid var(--border);
            color: var(--text-dim);
            font-size: 11px;
            text-align: left;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .task-table td {
            padding: 10px 14px;
            border-bottom: 1px solid var(--border);
            font-size: 13px;
        }
        .status-pill {
            display: inline-block;
            padding: 2px 10px;
            border-radius: 12px;
            font-size: 11px;
            font-weight: 700;
        }
        .status-done { background: rgba(34,197,94,0.12); color: var(--green); }
        .status-failed { background: rgba(239,68,68,0.12); color: var(--red); }
        .status-pending { background: rgba(245,158,11,0.12); color: var(--amber); }
        .status-running { background: rgba(0,161,219,0.12); color: var(--accent-bright); }

        /* ── Doc Cards ── */
        .doc-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius);
            padding: 20px;
            text-decoration: none;
            color: inherit;
            display: flex;
            align-items: center;
            gap: 14px;
            transition: border-color 0.2s;
        }
        .doc-card:hover { border-color: var(--border-hover); }
        .doc-card .doc-icon { font-size: 32px; flex-shrink: 0; }
        .doc-card .doc-name { font-weight: 700; color: white; font-size: 14px; margin-bottom: 3px; }
        .doc-card .doc-desc { font-size: 12px; color: var(--text-muted); }

        /* ── Loading ── */
        .loading-overlay {
            position: fixed;
            top: 0; left: 0; right: 0; bottom: 0;
            background: rgba(0,26,45,0.9);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 1000;
        }
        .loading-overlay.active { display: flex; }
        .loading-spinner {
            width: 36px;
            height: 36px;
            border: 3px solid var(--border);
            border-top-color: var(--accent);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }
        @keyframes spin { to { transform: rotate(360deg); } }

        /* ── Mobile Menu Button ── */
        .mobile-menu-btn {
            display: none;
            background: none;
            border: none;
            color: var(--text);
            font-size: 22px;
            cursor: pointer;
            padding: 4px 8px;
        }
        .mobile-menu-btn:hover { color: white; }

        /* ── Responsive ── */
        @media (max-width: 768px) {
            .mobile-menu-btn { display: block; }
            .nav-links { 
                display: none;
                position: absolute;
                top: 56px;
                left: 0;
                right: 0;
                background: rgba(0,26,45,0.98);
                border-bottom: 1px solid var(--border);
                flex-direction: column;
                padding: 8px;
                z-index: 200;
            }
            .nav-links.open { display: flex; }
            .nav-link { width: 100%; text-align: left; padding: 10px 16px; }
            .sidebar { width: 100%; position: fixed; z-index: 50; }
            .chat-area { width: 100%; }
            .nav { padding: 0 12px; }
            .content-tab { padding: 16px; }
            .services-grid { grid-template-columns: 1fr; }
            .metrics-grid { grid-template-columns: 1fr 1fr; }
        }
    </style>
</head>
<body>
    <!-- Login Screen -->
    <div class="login-screen" id="loginScreen">
        <div class="login-card">
            <h1>🛰️ SAOS Client Portal</h1>
            <p>Access your AI agent fleet and manage automations</p>
            <div class="form-group">
                <label>Client ID</label>
                <input type="text" id="clientId" placeholder="Enter your client ID" value="1">
            </div>
            <div class="form-group">
                <label>Access Token (optional)</label>
                <input type="password" id="accessToken" placeholder="Or paste your token">
            </div>
            <button class="btn btn-primary" onclick="login()">Access Dashboard</button>
            <div class="error-msg" id="loginError"></div>
        </div>
    </div>

    <!-- Main App -->
    <div class="app-container" id="appContainer">
        <!-- Navigation -->
        <nav class="nav">
            <a href="#" class="nav-brand">🛰️ SAOS</a>
            <button class="mobile-menu-btn" onclick="document.querySelector('.nav-links').classList.toggle('open')">☰</button>
            <div class="nav-links">
                <button class="nav-link active" onclick="showTab('chat')">💬 Chat</button>
                <button class="nav-link" onclick="showTab('dashboard')">📊 Dashboard</button>
                <button class="nav-link" onclick="showTab('services')">📦 Services</button>
                <button class="nav-link" onclick="showTab('tasks')">✅ Tasks</button>
                <button class="nav-link" onclick="showTab('activity')">📋 Activity</button>
                <button class="nav-link" onclick="showTab('docs')">📄 Docs</button>
            </div>
            <div class="nav-right">
                <span class="badge-unread" id="navUnread" style="display:none">0</span>
                <div class="nav-avatar" id="userAvatar">?</div>
                <span class="nav-client-name" id="userName">Loading...</span>
                <button class="btn btn-secondary btn-sm" onclick="logout()">Logout</button>
            </div>
        </nav>

        <div class="app-body">
            <!-- Chat Tab (Default) -->
            <div id="chatTab" style="display:flex; flex:1">
                <!-- Sidebar -->
                <div class="sidebar">
                    <div class="sidebar-header">
                        <h2>Conversations</h2>
                        <button class="btn btn-primary new-chat-btn" onclick="createConversation()">+ New Chat</button>
                    </div>
                    <div class="conversation-list" id="conversationList"></div>
                </div>

                <!-- Chat Area -->
                <div class="chat-area">
                    <div class="chat-header" id="chatHeader">
                        <div class="chat-header-info">
                            <h3 id="chatTitle">Select a conversation</h3>
                            <p id="chatSubtitle">Choose from the sidebar or start a new chat</p>
                        </div>
                        <div class="chat-status" id="chatStatus" style="display:none">
                            <span class="status-dot"></span>
                            <span>Agents Online</span>
                        </div>
                    </div>

                    <div class="messages-container" id="messagesContainer">
                        <div class="empty-chat">
                            <div class="empty-chat-icon">💬</div>
                            <h3>Welcome to SAOS Chat</h3>
                            <p>Start a conversation with your AI agent fleet. Request tasks, ask questions, or get updates on your automations.</p>
                        </div>
                    </div>

                    <div class="typing-indicator" id="typingIndicator">
                        <span>SOL is typing</span>
                        <div class="typing-dots">
                            <span></span><span></span><span></span>
                        </div>
                    </div>

                    <div class="input-area" id="inputArea" style="display:none">
                        <textarea class="message-input" id="messageInput" placeholder="Type your message... (Enter to send, Shift+Enter for new line)" rows="1"></textarea>
                        <button class="send-btn" onclick="sendMessage()">Send</button>
                    </div>
                </div>
            </div>

            <!-- Dashboard Tab -->
            <div class="content-tab" id="dashboardTab" style="display:none">
                <h2>📊 Fleet Status</h2>
                <div id="dashboardContent">Loading...</div>
            </div>

            <!-- Services Tab (NEW) -->
            <div class="content-tab" id="servicesTab" style="display:none">
                <h2>📦 Your Services</h2>
                <div id="servicesContent">Loading...</div>
            </div>

            <!-- Tasks Tab -->
            <div class="content-tab" id="tasksTab" style="display:none">
                <h2>✅ Your Tasks</h2>
                <div id="tasksContent">Loading...</div>
            </div>

                    <!-- Activity Log Tab -->
        <div class="content-tab" id="activityTab" style="display:none">
            <h2 style="color:white; margin-bottom:24px">📋 Activity Log</h2>
            <div id="activityContent">Loading...</div>
        </div>

        <!-- Documents Tab -->
        <div class="content-tab" id="docsTab" style="display:none">
            <h2 style="color:white; margin-bottom:24px">📄 Documentation</h2>
            <div id="docsContent">Loading...</div>
        </div>
        </div>
    </div>

    <!-- Loading Overlay -->
    <div class="loading-overlay" id="loadingOverlay">
        <div class="loading-spinner"></div>
    </div>

    <script>
        // ── STATE ──────────────────────────────────────────────
        let token = localStorage.getItem('saos_token');
        let client = null;
        let conversations = [];
        let currentConvId = null;
        let messages = [];
        let pollInterval = null;
        let lastPollTime = new Date().toISOString();

        // ── API HELPERS ────────────────────────────────────────
        const API_BASE = '';

        async function api(method, endpoint, body = null) {
            const opts = {
                method,
                headers: {
                    'Authorization': `Bearer ${token}`,
                    'Content-Type': 'application/json'
                }
            };
            if (body) opts.body = JSON.stringify(body);

            const res = await fetch(`${API_BASE}${endpoint}`, opts);
            if (res.status === 401) {
                logout();
                throw new Error('Session expired');
            }
            return res.json();
        }

        // ── AUTH ───────────────────────────────────────────────
        async function login() {
            const clientId = document.getElementById('clientId').value;
            const existingToken = document.getElementById('accessToken').value;

            if (existingToken) {
                token = existingToken;
            } else {
                try {
                    const res = await fetch(`${API_BASE}/api/auth/login`, {
                        method: 'POST',
                        headers: {'Content-Type': 'application/json'},
                        body: JSON.stringify({client_id: clientId})
                    });
                    const data = await res.json();
                    if (data.error) throw new Error(data.error);
                    token = data.token;
                } catch (e) {
                    document.getElementById('loginError').textContent = e.message;
                    return;
                }
            }

            localStorage.setItem('saos_token', token);
            await initApp();
        }

        function logout() {
            localStorage.removeItem('saos_token');
            token = null;
            location.reload();
        }

        // ── INIT ───────────────────────────────────────────────
        async function initApp() {
            if (!token) return;

            try {
                client = await api('GET', '/api/auth/me');
                if (client.error) throw new Error(client.error);

                document.getElementById('loginScreen').style.display = 'none';
                document.getElementById('appContainer').classList.add('active');
                document.getElementById('userName').textContent = client.customer_name || 'Client';
                document.getElementById('userAvatar').textContent = (client.customer_name || 'C')[0].toUpperCase();

                await loadConversations();
                startPolling();
            } catch (e) {
                console.error('Init failed:', e);
                logout();
            }
        }

        // ── CONVERSATIONS ──────────────────────────────────────
        async function loadConversations() {
            conversations = await api('GET', '/api/chat/conversations');
            renderConversationList();
        }

        function renderConversationList() {
            const list = document.getElementById('conversationList');
            if (!conversations.length) {
                list.innerHTML = '<div style="padding:20px; color:var(--text-dim); text-align:center; font-size:13px">No conversations yet</div>';
                return;
            }

            list.innerHTML = conversations.map(conv => `
                <div class="conversation-item ${conv.id === currentConvId ? 'active' : ''}" onclick="selectConversation(${conv.id})">
                    <div class="conv-title">${conv.title || 'Untitled'}</div>
                    <div class="conv-preview">${conv.last_message || 'No messages yet'}</div>
                    <div class="conv-meta">
                        <span class="conv-time">${formatTime(conv.last_message_at || conv.updated_at)}</span>
                        ${conv.unread_count > 0 ? `<span class="conv-unread">${conv.unread_count}</span>` : ''}
                    </div>
                </div>
            `).join('');

            const totalUnread = conversations.reduce((sum, c) => sum + (c.unread_count || 0), 0);
            const badge = document.getElementById('navUnread');
            if (totalUnread > 0) {
                badge.textContent = totalUnread;
                badge.style.display = 'inline-block';
            } else {
                badge.style.display = 'none';
            }
        }

        async function createConversation() {
            const title = prompt('Conversation title (optional):') || 'New Conversation';
            const conv = await api('POST', '/api/chat/conversations', {title});
            if (conv.error) {
                alert('Failed to create conversation: ' + conv.error);
                return;
            }
            await loadConversations();
            selectConversation(conv.id);
        }

        async function selectConversation(convId) {
            currentConvId = convId;
            renderConversationList();

            const conv = conversations.find(c => c.id === convId);
            document.getElementById('chatTitle').textContent = conv?.title || 'Conversation';
            document.getElementById('chatSubtitle').textContent = 'Active';
            document.getElementById('chatStatus').style.display = 'flex';
            document.getElementById('inputArea').style.display = 'flex';

            await loadMessages(convId);
        }

        // ── MESSAGES ───────────────────────────────────────────
        async function loadMessages(convId) {
            messages = await api('GET', `/api/chat/conversations/${convId}/messages`);
            renderMessages();
        }

        function renderMessages() {
            const container = document.getElementById('messagesContainer');
            if (!messages.length) {
                container.innerHTML = `
                    <div class="empty-chat">
                        <div class="empty-chat-icon">💬</div>
                        <h3>Start the conversation</h3>
                        <p>Send a message to begin chatting with your AI agents.</p>
                    </div>
                `;
                return;
            }

            container.innerHTML = messages.map(msg => renderMessage(msg)).join('');
            scrollToBottom();
        }

        function renderMessage(msg) {
            const isClient = msg.sender_type === 'client';
            const isSystem = msg.sender_type === 'system';
            const avatar = isClient ? '👤' : (msg.sender_agent || '🛰️');
            const time = formatTime(msg.created_at);

            let taskBadge = '';
            if (msg.task_id) {
                taskBadge = `<span class="task-pill">Task #${msg.task_id}</span>`;
            }

            return `
                <div class="message ${msg.sender_type}">
                    ${!isSystem ? `<div class="message-avatar">${avatar}</div>` : ''}
                    <div>
                        <div class="message-content">${escapeHtml(msg.content)}</div>
                        <div class="message-meta">
                            <span>${msg.sender_name}</span>
                            <span>•</span>
                            <span>${time}</span>
                            ${taskBadge}
                        </div>
                    </div>
                </div>
            `;
        }

        async function sendMessage() {
            const input = document.getElementById('messageInput');
            const content = input.value.trim();
            if (!content || !currentConvId) return;

            input.value = '';
            input.style.height = '42px';

            const tempMsg = {
                id: 'temp-' + Date.now(),
                sender_type: 'client',
                sender_name: 'You',
                content: content,
                created_at: new Date().toISOString()
            };
            messages.push(tempMsg);
            renderMessages();

            document.getElementById('typingIndicator').classList.add('active');

            try {
                const msg = await api('POST', `/api/chat/conversations/${currentConvId}/messages`, {content});
                if (msg.error) throw new Error(msg.error);

                const idx = messages.findIndex(m => m.id === tempMsg.id);
                if (idx >= 0) messages[idx] = msg;

                await loadMessages(currentConvId);
            } catch (e) {
                console.error('Send failed:', e);
                alert('Failed to send message: ' + e.message);
            } finally {
                document.getElementById('typingIndicator').classList.remove('active');
            }
        }

        // ── POLLING ────────────────────────────────────────────
        function startPolling() {
            if (pollInterval) clearInterval(pollInterval);
            pollInterval = setInterval(pollUpdates, 5000);
        }

        async function pollUpdates() {
            try {
                const data = await api('GET', `/api/chat/poll?since=${encodeURIComponent(lastPollTime)}`);
                lastPollTime = data.timestamp;

                if (data.messages && data.messages.length > 0) {
                    if (currentConvId) await loadMessages(currentConvId);
                    await loadConversations();
                }

                if (data.task_updates && data.task_updates.length > 0) {
                    console.log('Task updates:', data.task_updates);
                }
            } catch (e) {
                console.error('Poll error:', e);
            }
        }

        // ── TABS ───────────────────────────────────────────────
        function showTab(tab) {
            // Hide all
            ['chatTab','dashboardTab','servicesTab','tasksTab','activityTab','docsTab'].forEach(id => {
                document.getElementById(id).style.display = 'none';
            });

            // Show selected
            const el = document.getElementById(tab + 'Tab');
            el.style.display = tab === 'chat' ? 'flex' : 'block';

            // Update nav
            document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
            // Find the button by onclick attribute
            const buttons = document.querySelectorAll('.nav-link');
            buttons.forEach(b => {
                const onclick = b.getAttribute('onclick');
                if (onclick && onclick.includes(`showTab('${tab}')`)) b.classList.add('active');
            });

            // Load content
            if (tab === 'dashboard') loadDashboard();
            if (tab === 'services') loadServices();
            if (tab === 'tasks') loadTasks();
            if (tab === 'activity') loadActivity();
            if (tab === 'docs') loadDocs();
        }

        // ── DASHBOARD ──────────────────────────────────────────
        async function loadDashboard() {
            const data = await api('GET', '/api/portal/status');
            const tier = client?.tier || 'business';
            
            // Calculate setup progress
            const services = getServicesForTier(tier);
            const activeCount = services.filter(s => s.status === 'active').length;
            const totalCount = services.length;
            const progressPct = Math.round((activeCount / totalCount) * 100);

            document.getElementById('dashboardContent').innerHTML = `
                <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px">
                    <span class="tier-badge tier-${tier.toLowerCase().replace('+','-plus')}">${getTierLabel(tier)}</span>
                    <span style="font-size:13px; color:var(--text-muted)">Current plan</span>
                    <span style="margin-left:auto; font-size:12px; color:var(--text-dim)">
                        Setup: <span style="color:var(--accent-bright)">${progressPct}%</span> complete
                    </span>
                </div>
                
                <!-- Setup Progress Bar -->
                <div style="background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius); padding:20px; margin-bottom:24px">
                    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:12px">
                        <div style="font-weight:600; color:white; font-size:14px">🚀 Setup Progress</div>
                        <div style="font-size:13px; color:var(--text-muted)">${activeCount} of ${totalCount} services active</div>
                    </div>
                    <div style="width:100%; height:8px; background:rgba(255,255,255,0.05); border-radius:4px; overflow:hidden">
                        <div style="width:${progressPct}%; height:100%; background:linear-gradient(90deg, var(--accent), var(--accent-bright)); border-radius:4px; transition:width 0.3s"></div>
                    </div>
                    <div style="margin-top:12px; font-size:12px; color:var(--text-dim)">
                        ${progressPct < 100 ? `<span style="color:var(--amber)">⚠️ ${totalCount - activeCount} services need configuration.</span> Chat with SOL to complete setup.` : '✅ All services configured and running.'}
                    </div>
                </div>

                <div class="metrics-grid">
                    <div class="metric-card">
                        <div class="metric-label">Active Tasks</div>
                        <div class="metric-value">${data.tasks?.RUNNING || 0}</div>
                        <div class="metric-sub">Currently processing</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Pending</div>
                        <div class="metric-value" style="color:var(--amber)">${data.tasks?.PENDING || 0}</div>
                        <div class="metric-sub">Awaiting agent</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Completed</div>
                        <div class="metric-value" style="color:var(--green)">${data.tasks?.DONE || 0}</div>
                        <div class="metric-sub">All time</div>
                    </div>
                    <div class="metric-card">
                        <div class="metric-label">Unread Messages</div>
                        <div class="metric-value" style="color:var(--accent-bright)">${data.unread_messages || 0}</div>
                        <div class="metric-sub">From agents</div>
                    </div>
                </div>

                <h3>Agent Fleet</h3>
                <div class="agents-grid">
                    ${(data.agents || []).map(a => {
                        const isActive = a.agent_name === 'SOL';
                        const lastActivity = isActive ? 'Active now — 20 tasks today' : 'Idle';
                        return `
                        <div class="agent-card" style="${isActive ? 'border-color:var(--border-hover)' : ''}">
                            <div class="agent-icon">${a.avatar || '🛰️'}</div>
                            <div>
                                <div class="agent-name">${a.agent_name}</div>
                                <div class="agent-status" style="${isActive ? 'color:var(--green)' : ''}">${lastActivity}</div>
                                <div class="agent-role">${a.role || ''}</div>
                            </div>
                        </div>
                        `;
                    }).join('')}
                </div>
            `;
        }

        // ── SERVICES (NEW — tier-specific content) ─────────────
        function loadServices() {
            const tier = client?.tier || 'business';
            const services = getServicesForTier(tier);
            
            const activeCount = services.filter(s => s.status === 'active').length;
            const pendingCount = services.filter(s => s.status === 'pending').length;

            document.getElementById('servicesContent').innerHTML = `
                <div style="display:flex; align-items:center; gap:12px; margin-bottom:20px">
                    <span class="tier-badge tier-${tier.toLowerCase().replace('+','-plus')}">${getTierLabel(tier)}</span>
                    <span style="font-size:13px; color:var(--text-muted)">Your included services</span>
                    <span style="margin-left:auto; font-size:12px; color:var(--text-dim)">
                        <span style="color:var(--green)">● ${activeCount} Active</span> | 
                        <span style="color:var(--amber)">● ${pendingCount} Setup Required</span>
                    </span>
                </div>

                <div class="services-grid">
                    ${services.map(s => `
                        <div class="service-card">
                            <div class="svc-icon">${s.icon}</div>
                            <div class="svc-name">${s.name}</div>
                            <div class="svc-desc">${s.desc}</div>
                            <div class="svc-meta">
                                <span class="svc-status ${s.status === 'active' ? 'svc-active' : 'svc-pending'}">
                                    ${s.status === 'active' ? '🟢 Active' : '🟡 Setup Required'}
                                </span>
                                ${s.lastRun ? `<span class="svc-last-run">Last run: ${s.lastRun}</span>` : ''}
                                ${s.runsToday ? `<span class="svc-runs-today">${s.runsToday} today</span>` : ''}
                            </div>
                            ${s.note ? `<div class="svc-note">${s.note}</div>` : ''}
                        </div>
                    `).join('')}
                </div>

                <h3>Infrastructure</h3>
                <div style="display:grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap:10px">
                    ${getInfraForTier(tier).map(i => `
                        <div class="agent-card">
                            <div class="agent-icon">${i.icon}</div>
                            <div>
                                <div class="agent-name">${i.name}</div>
                                <div class="agent-status">${i.value}</div>
                            </div>
                        </div>
                    `).join('')}
                </div>

                <h3>Setup Checklist</h3>
                <div style="background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius); padding:20px">
                    <div id="setupChecklist">
                        ${services.filter(s => s.status === 'pending').map(s => `
                            <div style="display:flex; align-items:center; gap:12px; padding:10px 0; border-bottom:1px solid var(--border)">
                                <div style="width:20px; height:20px; border:2px solid var(--border); border-radius:4px; flex-shrink:0"></div>
                                <div style="flex:1">
                                    <div style="font-size:13px; color:white; font-weight:600">${s.name}</div>
                                    <div style="font-size:12px; color:var(--text-dim)">${s.note || 'Configuration needed'}</div>
                                </div>
                                <button class="btn btn-primary btn-sm" onclick="requestSetup('${s.name}')">Setup</button>
                            </div>
                        `).join('') || '<div style="color:var(--green); text-align:center; padding:20px">✅ All services configured!</div>'}
                    </div>
                </div>

                <h3>Support</h3>
                <div style="background:var(--bg-card); border:1px solid var(--border); border-radius:var(--radius); padding:20px">
                    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:16px; font-size:13px">
                        ${getSupportForTier(tier).map(s => `
                            <div>
                                <div style="color:var(--text-dim); font-size:11px; text-transform:uppercase; letter-spacing:0.5px; margin-bottom:2px">${s.label}</div>
                                <div style="color:white; font-weight:600">${s.value}</div>
                            </div>
                        `).join('')}
                    </div>
                </div>
            `;
        }

        // ── TASKS ──────────────────────────────────────────────
        async function loadTasks() {
            const tasks = await api('GET', '/api/portal/tasks');
            document.getElementById('tasksContent').innerHTML = tasks.length ? `
                <table class="task-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Type</th>
                            <th>Agent</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th>Details</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${tasks.map(t => {
                            let detail = '';
                            if (t.status === 'FAILED' && t.error_message) {
                                detail = `<span style="color:var(--red); font-size:12px" title="${escapeHtml(t.error_message)}">${escapeHtml(t.error_message.substring(0, 60))}${t.error_message.length > 60 ? '...' : ''}</span>`;
                            } else if (t.status === 'DONE' && t.completed_at) {
                                detail = `<span style="color:var(--green); font-size:12px">Completed ${formatTime(t.completed_at)}</span>`;
                            } else if (t.status === 'RUNNING') {
                                detail = `<span style="color:var(--accent-bright); font-size:12px">In progress</span>`;
                            } else {
                                detail = `<span style="color:var(--text-dim); font-size:12px">—</span>`;
                            }
                            return `
                            <tr>
                                <td style="color:var(--accent-bright)">#${t.id}</td>
                                <td>${t.task_type}</td>
                                <td>${t.assigned_agent || '-'}</td>
                                <td>
                                    <span class="status-pill status-${t.status.toLowerCase()}">${t.status}</span>
                                </td>
                                <td style="color:var(--text-dim)">${formatTime(t.created_at)}</td>
                                <td>${detail}</td>
                            </tr>
                            `;
                        }).join('')}
                    </tbody>
                </table>
            ` : '<div style="color:var(--text-dim); text-align:center; padding:40px">No tasks yet. Start a chat conversation to create tasks.</div>';
        }

        // ── DOCS ────────────────────────────────────────────────
        function loadDocs() {
            const tier = client?.tier || 'business';
            const docs = getDocsForTier(tier);

            document.getElementById('docsContent').innerHTML = `
                <div style="display:grid; gap:12px">
                    ${docs.map(d => `
                        <a href="${d.url}" target="_blank" class="doc-card">
                            <div class="doc-icon">${d.icon}</div>
                            <div>
                                <div class="doc-name">${d.name}</div>
                                <div class="doc-desc">${d.desc}</div>
                            </div>
                        </a>
                    `).join('')}
                </div>
            `;
        }

        // ── TIER DATA ───────────────────────────────────────────
        function getTierLabel(tier) {
            const labels = {
                'personal': 'Personal ($49/mo)',
                'personal+': 'Personal+ ($99/mo)',
                'business': 'Business Fleet ($299/mo)',
                'enterprise': 'Enterprise Fleet ($799/mo)',
                'private': 'Systack Private ($799/mo)',
                'accelerate': 'Systack Accelerate ($249/mo)'
            };
            return labels[tier] || tier;
        }

        function getServicesForTier(tier) {
            const all = {
                'personal': [
                    { icon: '📧', name: 'Email Triage & Drafting', desc: 'Auto-sort, summarize, and draft replies for your inbox.', status: 'active' },
                    { icon: '📅', name: 'Calendar Management', desc: 'Schedule, reschedule, and send reminders for appointments.', status: 'active' },
